{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["scripts/**/*", "hardhat.config.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
